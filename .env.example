# ─────────────────────────────────────────────────────────────
# The AEO Loop — environment variables
# Copy to ".env" for LOCAL dev only. In production, set these in
# Vercel → Project → Settings → Environment Variables.
# NEVER commit real keys to git. The scanner reads ONLY from these.
# If a key is missing, that engine gracefully falls back to demo mode.
# ─────────────────────────────────────────────────────────────

# --- Engine API keys (scanner) ---
OPENAI_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Lead capture (Google Sheet via Apps Script webhook) ---
# SHEET_WEBHOOK_URL: the Apps Script web app URL ending in /exec
# SHEET_WEBHOOK_SECRET: must match SHARED_SECRET in the Apps Script
SHEET_WEBHOOK_URL=
SHEET_WEBHOOK_SECRET=

# --- Gap Report email delivery (Resend) ---
# Report drafts are emailed to the founder for review before sending.
RESEND_API_KEY=
